{
  "version": 2,
  "installCommand": "corepack enable && pnpm install --no-frozen-lockfile",
  "buildCommand": "pnpm --filter @workspace/ielts-tracker run build",
  "outputDirectory": "artifacts/ielts-tracker/dist",
  "framework": null,
  "functions": {
    "api/index.mjs": {
      "memory": 512,
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index.mjs" },
    { "source": "/((?!api).*)", "destination": "/index.html" }
  ]
}
